import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import EntryCard from '@components/ListView/EntryCard.astro';
import KnowledgeGraph from '@components/KnowledgeGraph/index.tsx';

const allEntries = await getCollection('entries', ({ data }) => !data.draft);
const entries = allEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const allTags = [...new Set(entries.flatMap((e) => e.data.tags))].sort();
const activeTag = Astro.url.searchParams.get('tag') ?? '';
const initialCenter = `article-${entries[0]?.slug ?? ''}`;
---

<BaseLayout>

  <!-- Header — constrained column -->
  <div class="max-w-3xl mx-auto px-6 pt-10 pb-6">
    <div class="flex items-start justify-between">
      <div>
        <a href="https://brad-duhon.com" class="text-xs font-mono text-site-muted hover:text-amber-dark transition-colors">
          brad-duhon.com ↗
        </a>
        <h1 class="text-2xl font-bold text-site-heading mt-1">
          <span class="border-b-2 border-amber-primary pb-1">Lab</span>
        </h1>
      </div>
      <div class="flex items-center gap-3 mt-1">
        <div class="flex items-center border border-amber-light rounded overflow-hidden text-xs font-mono">
          <button id="btn-graph" class="px-3 py-1.5 bg-amber-primary text-white transition-colors">
            Graph
          </button>
          <button id="btn-list" class="px-3 py-1.5 text-site-muted hover:text-amber-dark transition-colors">
            List
          </button>
        </div>
        <a href="/rss.xml" class="text-xs font-mono text-site-muted hover:text-amber-dark transition-colors">RSS</a>
      </div>
    </div>
    <p class="text-sm text-site-muted mt-3">
      Security research, cloud experiments, homelab notes, and TILs.
      No rigid categories - tags do the sorting.
    </p>
  </div>

  <!-- Graph view — full viewport width, breaks out of column -->
  <div
    id="view-graph"
    class="w-full border-t border-b border-amber-light bg-site-bg"
    style="height: clamp(520px, 74vh, 960px); position: relative;"
  >
    <KnowledgeGraph initialCenterId={initialCenter} client:load />
  </div>

  <style>
    /* Ensure astro-island wrapper fills the graph container so height: 100%
       resolves correctly through the full element chain. */
    #view-graph > astro-island {
      display: block;
      position: absolute;
      inset: 0;
    }
  </style>

  <!-- List view — constrained column, hidden by default -->
  <div id="view-list" class="hidden max-w-3xl mx-auto px-6 py-8">
    <div id="search" class="mb-6"></div>

    <div class="flex flex-wrap gap-2 mb-8" id="tag-filters">
      <button
        data-tag=""
        class="tag-pill text-xs font-mono px-3 py-1 rounded border transition-colors border-amber-primary bg-amber-primary text-white"
      >
        All
      </button>
      {allTags.map((tag) => (
        <button
          data-tag={tag}
          class="tag-pill text-xs font-mono px-3 py-1 rounded border transition-colors border-amber-light text-site-muted hover:border-amber-primary hover:text-amber-dark"
        >
          {tag}
        </button>
      ))}
    </div>

    <div class="grid gap-8" id="entry-list">
      {entries.map((entry, i) => (
        <EntryCard
          title={entry.data.title}
          description={entry.data.description}
          date={entry.data.date}
          tags={entry.data.tags}
          slug={entry.slug}
          featured={i === 0}
        />
      ))}
    </div>
  </div>

</BaseLayout>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>

<script define:vars={{ activeTag }}>
  const btnGraph  = document.getElementById('btn-graph');
  const btnList   = document.getElementById('btn-list');
  const viewGraph = document.getElementById('view-graph');
  const viewList  = document.getElementById('view-list');

  function showGraph() {
    viewGraph.classList.remove('hidden');
    viewList.classList.add('hidden');
    btnGraph.classList.add('bg-amber-primary', 'text-white');
    btnGraph.classList.remove('text-site-muted');
    btnList.classList.remove('bg-amber-primary', 'text-white');
    btnList.classList.add('text-site-muted');
  }

  function showList() {
    viewList.classList.remove('hidden');
    viewGraph.classList.add('hidden');
    btnList.classList.add('bg-amber-primary', 'text-white');
    btnList.classList.remove('text-site-muted');
    btnGraph.classList.remove('bg-amber-primary', 'text-white');
    btnGraph.classList.add('text-site-muted');
    if (window.PagefindUI && !document.querySelector('#search .pagefind-ui')) {
      new PagefindUI({ element: '#search', showSubResults: false, resetStyles: false });
    }
  }

  btnGraph.addEventListener('click', showGraph);
  btnList.addEventListener('click', showList);

  const pills = document.querySelectorAll('.tag-pill');
  const cards = document.querySelectorAll('.entry-card');

  function applyFilter(tag) {
    pills.forEach((p) => {
      const active = p.dataset.tag === tag;
      p.classList.toggle('border-amber-primary', active);
      p.classList.toggle('bg-amber-primary', active);
      p.classList.toggle('text-white', active);
      p.classList.toggle('border-amber-light', !active);
      p.classList.toggle('text-site-muted', !active);
    });
    cards.forEach((c) => {
      const tags = c.dataset.tags ? c.dataset.tags.split(',') : [];
      c.style.display = !tag || tags.includes(tag) ? '' : 'none';
    });
    const url = new URL(window.location);
    tag ? url.searchParams.set('tag', tag) : url.searchParams.delete('tag');
    window.history.replaceState({}, '', url);
  }

  pills.forEach((p) => p.addEventListener('click', () => applyFilter(p.dataset.tag ?? '')));

  if (activeTag) { showList(); applyFilter(activeTag); }
</script>
