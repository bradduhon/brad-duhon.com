const modules = import.meta.glob('../../../lab/src/content/entries/*.md', { eager: true });

const entries = Object.entries(modules)
  .map(([path, mod]: [string, any]) => ({
    slug: path.split('/').pop()!.replace('.md', ''),
    ...mod.frontmatter,
  }))
  .filter((e) => !e.draft)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
---

<section id="lab" class="max-w-3xl mx-auto px-6 py-16 border-t border-amber-light">
  <div class="flex items-baseline justify-between mb-8">
    <h2 class="text-2xl font-bold text-site-heading">
      <span class="border-b-2 border-amber-primary pb-1">From the Lab</span>
    </h2>
    <a
      href="https://lab.brad-duhon.com"
      class="text-sm text-amber-dark hover:text-amber-dark transition-colors font-medium"
    >
      All entries ↗
    </a>
  </div>

  <ul class="grid gap-4">
    {entries.map((entry) => (
      <li>
        <a
          href={`https://lab.brad-duhon.com/${entry.slug}`}
          class="flex flex-col gap-2 border-l-2 border-amber-light hover:border-amber-primary transition-colors pl-4 py-1 group"
        >
          <span class="text-sm font-semibold text-site-heading group-hover:text-amber-dark transition-colors leading-snug">
            {entry.title}
          </span>
          <span class="text-xs text-site-muted">{new Date(entry.date).toISOString().slice(0, 10)}</span>
          <p class="text-sm text-site-muted leading-relaxed">{entry.description}</p>
          <ul class="flex flex-wrap gap-1.5">
            {entry.tags.map((tag) => (
              <li class="text-xs font-mono bg-amber-light text-amber-dark px-2 py-0.5 rounded">
                {tag}
              </li>
            ))}
          </ul>
        </a>
      </li>
    ))}
  </ul>
</section>
