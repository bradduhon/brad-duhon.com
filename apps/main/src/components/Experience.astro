---

<section id="experience" class="max-w-3xl mx-auto px-6 py-16 border-t border-amber-light">
  <h2 class="text-2xl font-bold text-site-heading mb-8">
    <span class="border-b-2 border-amber-primary pb-1">Experience</span>
  </h2>

  <div class="grid gap-8">
    {roles.map((role) => (
      <article>
        <div class="flex items-baseline justify-between gap-4 mb-1">
          <h3 class="font-semibold text-site-heading">{role.title}</h3>
          <span class="shrink-0 text-xs font-mono text-site-muted">{role.dates}</span>
        </div>
        <p class="text-sm text-amber-dark font-medium mb-3">{role.company}</p>
        <ul class="space-y-1.5">
          {role.bullets.map((bullet) => (
            <li class="text-sm text-site-text leading-relaxed pl-4 relative before:content-['–'] before:absolute before:left-0 before:text-amber-dark">
              {bullet}
            </li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</section>
