import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Brad Duhon" description="Page not found.">
  <main class="max-w-3xl mx-auto px-6 py-32 text-center">
    <p class="font-mono text-amber-dark text-sm mb-4">404</p>
    <h1 class="text-3xl font-bold text-site-heading mb-4">Access Denied</h1>
    <p class="text-site-text mb-8">This resource does not exist. Least privilege in action.</p>
    <a href="/" class="text-sm text-amber-dark hover:text-amber-dark transition-colors font-medium">
      ← Back to home
    </a>
  </main>
</BaseLayout>
